{
  "name": "@kkito/llm-gateway",
  "version": "1.2.1",
  "description": "LLM Proxy Gateway - 统一管理多个大模型 API",
  "author": "kkito",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kkito/llm-gateway"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPLv3",
  "bin": {
    "kkito-llm-gateway": "dist/cli/start.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "tsx scripts/copy-assets.ts",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/cli/start.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "version": "git add -A",
    "postversion": "git push && git push --tags",
    "publish:dry-run": "npm publish --dry-run",
    "publish:npm": "npm publish --access public"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@picocss/pico": "^2.1.1",
    "commander": "^14.0.3",
    "hono": "^4.12.8",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/uuid": "^11.0.0",
    "fs-extra": "^11.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.18.2"
}
